{
  "mcpServers": {
    "jira": {
      "command": "node",
      "args": ["./jira-mcp-server/build/index.js"],
      "env": {
        "JIRA_HOST": "your-domain.atlassian.net",
        "JIRA_EMAIL": "your-email@example.com",
        "JIRA_API_TOKEN": "your-api-token-here"
      },
      "alwaysAllow": ["search_issues"]
    }
  }
}


